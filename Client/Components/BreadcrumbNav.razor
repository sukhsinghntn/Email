@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject NavigationManager NavigationManager

<RadzenBreadCrumb Style="margin-bottom:5px;">
    <RadzenBreadCrumbItem Text="Home" Path="/" Icon="home" />
    @if (segments.Length > 0)
    {
        string path = string.Empty;
        for (int i = 0; i < segments.Length; i++)
        {
            path += "/" + segments[i];
            <RadzenBreadCrumbItem Text="@segments[i]" Path="@path" />
        }
    }
</RadzenBreadCrumb>

@code {
    private string[] segments = Array.Empty<string>();

    protected override void OnInitialized()
    {
        ParseSegments();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ParseSegments();
        InvokeAsync(StateHasChanged);
    }

    private void ParseSegments()
    {
        var rel = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        rel = rel.Split('?', 2)[0];
        segments = string.IsNullOrEmpty(rel) ? Array.Empty<string>() : rel.Split('/', StringSplitOptions.RemoveEmptyEntries);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
